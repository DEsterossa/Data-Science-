# GigaChat credentials (required for LLM steps)
GIGACHAT_AUTH_KEY=

# API scope (optional, default: GIGACHAT_API_PERS)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Model names — set per your GigaChat subscription
GIGACHAT_MODEL_DAILY=
GIGACHAT_MODEL_WEEKLY=
GIGACHAT_MODEL_REPORT=

# Request timeout in seconds (optional, default: 120)
GIGACHAT_TIMEOUT=120

# SSL (optional)
# GIGACHAT_VERIFY_SSL_CERTS=false
# GIGACHAT_CA_BUNDLE_FILE=

# Telegram bot token (optional, required for diarylens telegram-bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
