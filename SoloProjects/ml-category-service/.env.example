# Docker Compose: скопируйте в .env в корне репозитория и при необходимости измените порты.
# Если ошибка "port is already allocated" для 8000 или 8080 — задайте другие значения здесь
# и пересоберите frontend: docker compose build --no-cache frontend

BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=8080

# Backend (вне Docker): comma-separated browser origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8080

# Frontend (локальный npm run dev): см. frontend/.env.example
# VITE_API_BASE_URL=http://localhost:8000
